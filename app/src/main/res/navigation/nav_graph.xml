<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Global logout action -->
    <action
        android:id="@+id/action_global_logout"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_menu"
            app:destination="@id/customerHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_admin"
            app:destination="@id/adminPanelFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.register.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/menuFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.menu.MenuFragment"
        android:label="Menu">

        <action
            android:id="@+id/action_menu_to_cart"
            app:destination="@id/cartFragment" />

        <action
            android:id="@+id/action_menu_to_orders"
            app:destination="@id/ordersFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminPanelFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.admin.AdminPanelFragment"
        android:label="Admin Panel" />

    <fragment
        android:id="@+id/cartFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.cart.CartFragment"
        android:label="Cart">
        <action
            android:id="@+id/action_cart_to_checkout"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.checkout.CheckoutFragment"
        android:label="Checkout">
        <action
            android:id="@+id/action_checkout_to_status"
            app:destination="@id/orderStatusFragment"
            app:popUpTo="@id/menuFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/orderStatusFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.orderstatus.OrderStatusFragment"
        android:label="Order Status">
        <argument
            android:name="orderId"
            app:argType="long" />
        <argument
            android:name="simulate"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/ordersFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.orders.OrdersFragment"
        android:label="My Orders" />
    <fragment
        android:id="@+id/feedbackFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.feedback.FeedbackFragment"
        android:label="Feedback">
        <argument
            android:name="orderId"
            app:argType="long" />
    </fragment>
    <fragment
        android:id="@+id/productFeedbackFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.feedback.ProductFeedbackFragment"
        android:label="Product Feedback">
        <argument
            android:name="orderId"
            app:argType="long" />
        <argument
            android:name="orderItemId"
            app:argType="long" />
    </fragment>
    <fragment
        android:id="@+id/customerHomeFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.home.CustomerHomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/customerFavouritesFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.favourites.CustomerFavouritesFragment"
        android:label="Favourite" />

    <fragment
        android:id="@+id/customerRewardsFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.rewards.CustomerRewardsFragment"
        android:label="Rewards" />

    <fragment
        android:id="@+id/customerNotificationsFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.notifications.CustomerNotificationsFragment"
        android:label="Notifications" />

    <fragment
        android:id="@+id/customerInboxFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.inbox.CustomerInboxFragment"
        android:label="Inbox" />

    <fragment
        android:id="@+id/customerSettingsFragment"
        android:name="uk.ac.dmu.koffeecraft.ui.settings.CustomerSettingsFragment"
        android:label="Settings" />

</navigation>