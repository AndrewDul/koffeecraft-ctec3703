<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:endColor="#F0CF9D"
                android:startColor="#7D5136" />
        </shape>
    </item>
    <item
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#33FFF9F0" />
        </shape>
    </item>
    <item
        android:left="24dp"
        android:top="36dp"
        android:right="24dp"
        android:bottom="36dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="90"
                android:endColor="#FFF4E1"
                android:startColor="#9A6240" />
        </shape>
    </item>
</layer-list>