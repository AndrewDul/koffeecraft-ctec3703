<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:endColor="#D8B57B"
                android:startColor="#3F291E" />
        </shape>
    </item>
    <item
        android:left="18dp"
        android:top="18dp"
        android:right="18dp"
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#1EFFF6EA" />
        </shape>
    </item>
    <item
        android:left="24dp"
        android:top="24dp"
        android:right="24dp"
        android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#F6E1B0" />
        </shape>
    </item>
</layer-list>