<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="@color/kc_surface_panel"
    app:cardCornerRadius="22dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/kc_border_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivPickerProductImage"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/bg_spinner_soft"
            android:contentDescription="Reward picker image"
            android:scaleType="centerCrop"
            android:src="@drawable/kc_image_placeholder_generic" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPickerProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Latte"
                android:textColor="@color/kc_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPickerProductDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:text="Smooth espresso with milk."
                android:textColor="@color/kc_icon_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvPickerProductMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Base reward included"
                android:textColor="@color/kc_text_muted"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>