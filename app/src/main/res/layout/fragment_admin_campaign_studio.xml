<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kc_shell_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStudioHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/kc_surface_panel"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/kc_border_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Campaign Studio"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Build targeted offers, loyalty campaigns, and bonus beans rewards from one premium admin workspace."
                    android:textColor="@color/kc_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kc_surface_panel"
            app:cardCornerRadius="22dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/kc_border_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose Audience"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Select a customer segment first, then refine the campaign when extra rules are needed."
                    android:textColor="@color/kc_text_secondary"
                    android:textSize="13sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvAudienceAllOptedIn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_orders_filter_chip_selected"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="All opted-in"
                            android:textColor="@color/kc_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAudienceBirthdayToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_orders_filter_chip"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="Birthday today"
                            android:textColor="@color/kc_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAudienceNoOrders"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_orders_filter_chip"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="0 orders"
                            android:textColor="@color/kc_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAudienceLoyal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_orders_filter_chip"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="Loyal"
                            android:textColor="@color/kc_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAudienceInactive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_orders_filter_chip"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="Inactive"
                            android:textColor="@color/kc_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAudienceCloseReward"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_orders_filter_chip"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="Close to reward"
                            android:textColor="@color/kc_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAudienceDirectOrder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_orders_filter_chip"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="Direct by order"
                            android:textColor="@color/kc_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAudienceDirectCustomer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_orders_filter_chip"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp"
                            android:text="Direct by customer"
                            android:textColor="@color/kc_text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvAudienceRuleLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Rule"
                    android:textColor="@color/kc_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAudienceRule"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Rule value"
                    android:visibility="gone"
                    app:boxBackgroundColor="@color/kc_surface_secondary"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/kc_border_soft"
                    app:hintTextColor="@color/kc_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAudienceRule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/kc_text_primary"
                        android:textColorHint="@color/kc_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/kc_surface_panel"
            app:cardCornerRadius="22dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/kc_border_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Campaign Type"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Choose a campaign type built for promotions, loyalty, and beans rewards."
                    android:textColor="@color/kc_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypePromo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:minHeight="50dp"
                    android:text="Promotional Offer"
                    android:textAllCaps="false"
                    android:textColor="@color/kc_text_inverse"
                    android:textStyle="bold"
                    app:backgroundTint="@color/kc_brand_button"
                    app:cornerRadius="26dp"
                    app:elevation="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeBeans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="50dp"
                    android:text="Bonus Beans"
                    android:textAllCaps="false"
                    android:textColor="@color/kc_text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/kc_surface_chip"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    app:strokeColor="@color/kc_border_soft"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeOfferBeans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="50dp"
                    android:text="Offer + Bonus Beans"
                    android:textAllCaps="false"
                    android:textColor="@color/kc_text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/kc_surface_chip"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    app:strokeColor="@color/kc_border_soft"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/kc_surface_panel"
            app:cardCornerRadius="22dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/kc_border_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Campaign Builder"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBuilderHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Use [FIRST_NAME], [LAST_NAME], and [BEANS_AMOUNT] inside the message if you want simple personalisation."
                    android:textColor="@color/kc_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCampaignTitle"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Campaign title"
                    app:boxBackgroundColor="@color/kc_surface_secondary"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/kc_border_soft"
                    app:hintTextColor="@color/kc_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCampaignTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/kc_text_primary"
                        android:textColorHint="@color/kc_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCampaignMessage"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Campaign message"
                    app:boxBackgroundColor="@color/kc_surface_secondary"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/kc_border_soft"
                    app:hintTextColor="@color/kc_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCampaignMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:minLines="6"
                        android:textColor="@color/kc_text_primary"
                        android:textColorHint="@color/kc_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilBeansAmount"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Bonus beans amount"
                    android:visibility="gone"
                    app:boxBackgroundColor="@color/kc_surface_secondary"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/kc_border_soft"
                    app:hintTextColor="@color/kc_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBeansAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/kc_text_primary"
                        android:textColorHint="@color/kc_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/kc_surface_panel"
            app:cardCornerRadius="22dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/kc_border_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Preview"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPreviewAudienceValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Audience • All opted-in customers"
                    android:textColor="@color/kc_icon_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPreviewRecipientsValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Recipients • 0"
                    android:textColor="@color/kc_icon_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPreviewExcludedValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Excluded by consent • 0"
                    android:textColor="@color/kc_icon_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPreviewBeansTotalValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Total bonus beans • 0"
                    android:textColor="@color/kc_icon_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPreviewModeNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Promotional consent applies to this campaign."
                    android:textColor="@color/kc_text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPreviewSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0 customers will receive this message"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendCampaign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:enabled="false"
            android:minHeight="54dp"
            android:text="Send campaign"
            android:textAllCaps="false"
            android:textColor="@color/kc_text_inverse"
            android:textStyle="bold"
            app:backgroundTint="@color/kc_brand_button"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>