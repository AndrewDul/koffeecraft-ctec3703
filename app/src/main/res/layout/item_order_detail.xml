<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Latte"
            android:textColor="@color/kc_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailLineTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="£7.20"
            android:textColor="@color/kc_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDetailQuantityPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Qty 2 • £3.60 each"
        android:textColor="@color/kc_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvDetailCustomOption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Crafted • Large • 450ml"
        android:textColor="@color/kc_warning_text"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvDetailAddOns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:lineSpacingExtra="2dp"
        android:text="Add-ons • Vanilla, Oat Milk"
        android:textColor="@color/kc_text_muted"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvDetailCalories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="Approx. 210 kcal"
        android:textColor="@color/kc_text_muted"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>