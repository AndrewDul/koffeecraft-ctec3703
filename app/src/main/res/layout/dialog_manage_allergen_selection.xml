<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/kc_shell_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/kc_surface_panel"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/kc_border_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvAllergenSelectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Product allergens"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAllergenSelectionSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Select the allergens that apply."
                    android:textColor="@color/kc_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenAllergenLibrary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:minHeight="50dp"
                    android:text="Open allergen library"
                    android:textAllCaps="false"
                    android:textColor="@color/kc_text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/kc_surface_chip"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    app:strokeColor="@color/kc_border_soft"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvAllergenSelectionEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="No allergens available yet."
            android:textColor="@color/kc_text_muted"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/containerAllergenSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>