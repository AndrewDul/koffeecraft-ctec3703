<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kc_shell_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="0dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/kc_surface_panel"
        app:cardCornerRadius="26dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Orders"
                style="@style/TextAppearance.KoffeeCraft.ScreenTitle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Track, review and reorder your favourites."
                style="@style/TextAppearance.KoffeeCraft.ScreenSubtitle" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBrowseMenu"
                style="@style/Widget.KoffeeCraft.SecondaryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:paddingStart="18dp"
                android:paddingTop="11dp"
                android:paddingEnd="18dp"
                android:paddingBottom="11dp"
                android:text="Browse menu"
                android:textSize="13sp"
                app:iconPadding="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_orders_filter_chip_selected"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="15dp"
                android:paddingTop="10dp"
                android:paddingEnd="15dp"
                android:paddingBottom="10dp"
                android:text="All"
                android:textColor="@color/kc_text_primary"
                style="@style/TextAppearance.KoffeeCraft.FilterChipSmall" />

            <TextView
                android:id="@+id/filterToday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="15dp"
                android:paddingTop="10dp"
                android:paddingEnd="15dp"
                android:paddingBottom="10dp"
                android:text="Today"
                android:textColor="@color/kc_text_secondary"
                style="@style/TextAppearance.KoffeeCraft.FilterChipSmall" />

            <TextView
                android:id="@+id/filterYesterday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="15dp"
                android:paddingTop="10dp"
                android:paddingEnd="15dp"
                android:paddingBottom="10dp"
                android:text="Yesterday"
                android:textColor="@color/kc_text_secondary"
                style="@style/TextAppearance.KoffeeCraft.FilterChipSmall" />

            <TextView
                android:id="@+id/filterTwoDaysAgo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="15dp"
                android:paddingTop="10dp"
                android:paddingEnd="15dp"
                android:paddingBottom="10dp"
                android:text="2 days ago"
                android:textColor="@color/kc_text_secondary"
                style="@style/TextAppearance.KoffeeCraft.FilterChipSmall" />

            <TextView
                android:id="@+id/filterLast7Days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="15dp"
                android:paddingTop="10dp"
                android:paddingEnd="15dp"
                android:paddingBottom="10dp"
                android:text="Last 7 days"
                android:textColor="@color/kc_text_secondary"
                style="@style/TextAppearance.KoffeeCraft.FilterChipSmall" />

            <TextView
                android:id="@+id/filterLast14Days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="15dp"
                android:paddingTop="10dp"
                android:paddingEnd="15dp"
                android:paddingBottom="10dp"
                android:text="Last 14 days"
                android:textColor="@color/kc_text_secondary"
                style="@style/TextAppearance.KoffeeCraft.FilterChipSmall" />

            <TextView
                android:id="@+id/filterEarlier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="15dp"
                android:paddingTop="10dp"
                android:paddingEnd="15dp"
                android:paddingBottom="10dp"
                android:text="Earlier"
                android:textColor="@color/kc_text_secondary"
                style="@style/TextAppearance.KoffeeCraft.FilterChipSmall" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="No orders yet."
        style="@style/TextAppearance.KoffeeCraft.Body"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="20dp" />

</LinearLayout>