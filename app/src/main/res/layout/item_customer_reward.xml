<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/kc_surface_primary"
    app:cardCornerRadius="24dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/kc_border_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivReward"
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:background="@drawable/bg_spinner_soft"
                android:contentDescription="Reward image"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_gallery" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRewardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reward title"
                    android:textColor="#2E2018"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRewardDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Reward description"
                    android:textColor="@color/kc_icon_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Beans icon"
                    android:src="@drawable/coffee_bean" />

                <TextView
                    android:id="@+id/tvRewardBeans"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="15 beans"
                    android:textColor="#2E2018"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRewardAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Redeem"
            android:textAllCaps="false"
            android:textColor="@color/kc_surface_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/kc_success"
            app:cornerRadius="28dp"
            app:elevation="0dp"
            app:strokeWidth="0dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>