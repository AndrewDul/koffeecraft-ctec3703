<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F7F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFF8F2"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp"
            app:strokeColor="#E3D4C6"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvExtraAllergensTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Extra allergens"
                    android:textColor="#2E2018"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvExtraAllergensSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Choose an extra to manage its allergen disclosures."
                    android:textColor="#6E5A4D"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenAllergenLibraryForExtras"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:minHeight="50dp"
                    android:text="Open allergen library"
                    android:textAllCaps="false"
                    android:textColor="#5A4638"
                    android:textStyle="bold"
                    app:backgroundTint="#F2E5D8"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    app:strokeColor="#DDC9B8"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvExtraAllergensEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="No extras are assigned to this product yet."
            android:textColor="#7A6558"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/containerExtraAllergens"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>