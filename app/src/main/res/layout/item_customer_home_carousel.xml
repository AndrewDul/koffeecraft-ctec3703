<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="290dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="#EDE0D2"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:strokeColor="#D8C5B5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivHomeCarouselIcon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_reward_icon_circle"
                android:contentDescription="Carousel icon"
                android:padding="8dp"
                android:src="@drawable/coffee_bean" />

            <TextView
                android:id="@+id/tvHomeCarouselBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_secondary_pill_button"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="NEW"
                android:textColor="#6B4423"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHomeCarouselTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Latte"
            android:textColor="#2E2018"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeCarouselSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Smooth espresso with creamy milk and a soft crafted finish."
            android:textColor="#5B4638"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvHomeCarouselMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="★ 4.8 • 12 ratings • From £3.60"
            android:textColor="#7A6558"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>