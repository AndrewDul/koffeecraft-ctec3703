<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFF8F2"
    app:cardCornerRadius="24dp"
    app:cardElevation="1dp"
    app:strokeColor="#E3D4C6"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/layoutCollapsedHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivImage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:contentDescription="Product image"
                android:src="@android:drawable/ic_menu_gallery" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Latte"
                    android:textColor="#2E2018"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Coffee • Active"
                    android:textColor="#7A6558"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="From £3.60"
                    android:textColor="#2E2018"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBadges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="NEW • REWARD"
                    android:textColor="#8A5A2B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvExpandIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="▾"
                android:textColor="#8B6B4A"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTapHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tap to open full product details, actions, and configuration tools"
            android:textColor="#5B4638"
            android:textSize="12sp" />

        <View
            android:id="@+id/dividerExpanded"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="#EADFD4"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutExpanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvExpandedSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Overview"
                android:textColor="#7A6558"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExpandedDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:text="This product can be reviewed, edited, disabled, or permanently removed."
                android:textColor="#5B4638"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/layoutProductMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMetaAvailability"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Availability • Active"
                    android:textColor="#2E2018"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvMetaReward"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Reward Eligible • Yes"
                    android:textColor="#2E2018"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvMetaFamily"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Product Family • Coffee"
                    android:textColor="#2E2018"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvMetaListing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Listing Type • Standard Menu Item"
                    android:textColor="#2E2018"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvManageToolsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Management Actions"
                android:textColor="#7A6558"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:minHeight="48dp"
                android:text="Open configuration tools"
                android:textAllCaps="false"
                android:textColor="#2E2018"
                android:textStyle="bold"
                app:backgroundTint="#F3E8DD"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                app:strokeColor="#DDC9B8"
                app:strokeWidth="1dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnToggle"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Activate or deactivate product"
                        android:src="@android:drawable/ic_menu_manage" />

                    <ImageButton
                        android:id="@+id/btnEdit"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="10dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Edit product"
                        android:src="@android:drawable/ic_menu_edit" />

                    <ImageButton
                        android:id="@+id/btnDelete"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="10dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Delete product"
                        android:src="@android:drawable/ic_menu_delete" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvConfigHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="2dp"
                android:text="Use configuration tools to manage sizes, extras, allergens, and advanced product setup."
                android:textColor="#6E5A4D"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>