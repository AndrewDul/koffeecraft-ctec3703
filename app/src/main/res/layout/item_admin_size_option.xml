<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="#FAF4EE"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="#E6D8CC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvSizeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Large"
            android:textColor="#2E2018"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSizeMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="400 ml • +£0.50 • 180 kcal"
            android:textColor="#6E5A4D"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvSizeState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Default option"
            android:textColor="#8A5A2B"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="46dp"
                android:text="Edit size option"
                android:textAllCaps="false"
                android:textColor="#FFF8F2"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#9A7655"
                app:cornerRadius="24dp"
                app:elevation="0dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="46dp"
                android:text="Delete size option"
                android:textAllCaps="false"
                android:textColor="#5A4638"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#F2E5D8"
                app:cornerRadius="24dp"
                app:elevation="0dp"
                app:strokeColor="#DDC9B8"
                app:strokeWidth="1dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>