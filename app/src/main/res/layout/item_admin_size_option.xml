<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="@color/kc_surface_panel"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/kc_border_soft"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvSizeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Large"
            android:textColor="@color/kc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSizeMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="400 ml • +£0.50 • 180 kcal"
            android:textColor="@color/kc_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvSizeState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Default option"
            android:textColor="@color/kc_warning_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="46dp"
                android:text="Edit size option"
                android:textAllCaps="false"
                android:textColor="@color/kc_text_inverse"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@color/kc_brand_strong"
                app:cornerRadius="24dp"
                app:elevation="0dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="46dp"
                android:text="Delete size option"
                android:textAllCaps="false"
                android:textColor="@color/kc_text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@color/kc_surface_tertiary"
                app:cornerRadius="24dp"
                app:elevation="0dp"
                app:strokeColor="@color/kc_border_warm"
                app:strokeWidth="0dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>