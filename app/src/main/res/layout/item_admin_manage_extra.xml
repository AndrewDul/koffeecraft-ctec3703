<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="#FAF4EE"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="#E6D8CC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvExtraName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vanilla Syrup"
            android:textColor="#2E2018"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvExtraMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="£0.40 • 25 kcal"
            android:textColor="#6E5A4D"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvExtraState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Assigned • Active"
            android:textColor="#8A5A2B"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrimaryAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_pill_button"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="42dp"
                android:text="Assign"
                android:textAllCaps="false"
                android:textColor="#FFF8F2"
                android:textSize="12sp"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSecondaryAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_pill_button"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="42dp"
                android:text="Edit"
                android:textAllCaps="false"
                android:textColor="#6B4423"
                android:textSize="12sp"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTertiaryAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_pill_button"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="42dp"
                android:text="Disable"
                android:textAllCaps="false"
                android:textColor="#6B4423"
                android:textSize="12sp"
                app:cornerRadius="20dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>