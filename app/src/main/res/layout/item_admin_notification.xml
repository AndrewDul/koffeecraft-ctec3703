<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/kc_surface_panel"
    app:cardCornerRadius="24dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/kc_border_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvStatusChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_order_status_chip"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="Placed"
            android:textColor="@color/kc_text_section"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Order #123 needs action"
            android:textColor="@color/kc_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="Order #123 is currently placed and waiting for the next operational step."
            android:textColor="@color/kc_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Created 17 Mar 2026, 09:45 • Admin action queue"
            android:textColor="@color/kc_text_muted"
            android:textSize="12sp" />

        <View
            android:id="@+id/dividerActions"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="@color/kc_surface_chip"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutActionRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="Move to Preparing"
                android:textAllCaps="false"
                android:textColor="@color/kc_text_inverse"
                android:textStyle="bold"
                app:backgroundTint="@color/kc_brand_button"
                app:cornerRadius="26dp"
                app:elevation="0dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="48dp"
                android:text="Remove notification"
                android:textAllCaps="false"
                android:textColor="@color/kc_text_primary"
                android:textStyle="bold"
                app:backgroundTint="@color/kc_surface_tertiary"
                app:cornerRadius="26dp"
                app:elevation="0dp"
                app:strokeColor="@color/kc_border_warm"
                app:strokeWidth="1dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>