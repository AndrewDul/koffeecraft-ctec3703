<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kc_shell_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/adminTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/kc_shell_background"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgAdminLogo"
            android:layout_width="209dp"
            android:layout_height="58dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/kc_logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0" />

        <LinearLayout
            android:id="@+id/adminTopActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnAdminInbox"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:contentDescription="@string/cd_inbox"
                android:padding="10dp"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="@color/kc_icon_primary" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp">

                <ImageButton
                    android:id="@+id/btnAdminNotifications"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_orders_filter_chip"
                    android:contentDescription="@string/cd_notifications"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:tint="@color/kc_icon_primary" />

                <TextView
                    android:id="@+id/tvAdminNotificationBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|top"
                    android:background="@drawable/bg_topbar_badge"
                    android:gravity="center"
                    android:text="@string/badge_zero"
                    android:textColor="@color/kc_text_inverse"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnAdminSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:contentDescription="@string/cd_settings"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="@color/kc_icon_primary" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/adminNavHost"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/adminTopBar"
        app:navGraph="@navigation/admin_nav_graph" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/adminBottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/kc_surface_primary"
        app:itemIconTint="@color/kc_chip_text_selector"
        app:itemTextColor="@color/kc_chip_text_selector"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/admin_bottom_nav" />

</androidx.constraintlayout.widget.ConstraintLayout>