<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EBDD">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/adminTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvAdminLogo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="☕ KoffeeCraft"
            android:textColor="#2E2018"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/adminTopActions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/adminTopActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnAdminInbox"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:contentDescription="Inbox"
                android:padding="10dp"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="#5A4638" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp">

                <ImageButton
                    android:id="@+id/btnAdminNotifications"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_orders_filter_chip"
                    android:contentDescription="Notifications"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:tint="#5A4638" />

                <TextView
                    android:id="@+id/tvAdminNotificationBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|top"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#FFF8F2"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_topbar_badge"
                    android:visibility="gone" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnAdminSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_orders_filter_chip"
                android:contentDescription="Settings"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#5A4638" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/adminNavHost"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/adminTopBar"
        app:navGraph="@navigation/admin_nav_graph" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/adminBottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFF8F2"
        app:itemIconTint="@color/kc_chip_text_selector"
        app:itemTextColor="@color/kc_chip_text_selector"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/admin_bottom_nav" />

</androidx.constraintlayout.widget.ConstraintLayout>