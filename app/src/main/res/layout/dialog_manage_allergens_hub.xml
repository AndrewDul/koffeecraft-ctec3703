<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/kc_shell_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/kc_surface_panel"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/kc_border_soft"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvManageAllergensTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manage allergens"
                    android:textColor="@color/kc_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvManageAllergensSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Choose which allergen area you want to manage for this product."
                    android:textColor="@color/kc_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProductAllergens"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:minHeight="52dp"
                    android:text="Manage product allergens"
                    android:textAllCaps="false"
                    android:textColor="@color/kc_text_inverse"
                    android:textStyle="bold"
                    app:backgroundTint="@color/kc_brand_button"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExtraAllergens"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="52dp"
                    android:text="Manage extra allergens"
                    android:textAllCaps="false"
                    android:textColor="@color/kc_text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/kc_surface_chip"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    app:strokeColor="@color/kc_border_soft"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAllergenLibrary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="52dp"
                    android:text="Open allergen library"
                    android:textAllCaps="false"
                    android:textColor="@color/kc_text_primary"
                    android:textStyle="bold"
                    app:backgroundTint="@color/kc_surface_chip"
                    app:cornerRadius="26dp"
                    app:elevation="0dp"
                    app:strokeColor="@color/kc_border_soft"
                    app:strokeWidth="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>